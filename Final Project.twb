    <worksheet name='Sales vs Quantity'>
      <layout-options>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Sales generally increased as quantity increased, showing a </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>positive relationship</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> between order size and revenue. A few orders stood out as high-sales or high-quantity outliers, which may be worth reviewing to understand what drove larger purchases.</run>
          </formatted-text>
        </caption>
      </layout-options>
